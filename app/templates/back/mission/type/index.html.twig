{% extends 'base.html.twig' %}

{% block title %}MissionType index{% endblock %}

{% block body %}
    <h1>MissionType index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>CreatedAt</th>
                <th>UpdatedAt</th>
                <th>DeletedAt</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for mission_type in mission_types %}
            <tr>
                <td>{{ mission_type.id }}</td>
                <td>{{ mission_type.createdAt ? mission_type.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ mission_type.updatedAt ? mission_type.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ mission_type.deletedAt ? mission_type.deletedAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    <a href="{{ path('app_mission_type_show', {'id': mission_type.id}) }}">show</a>
                    <a href="{{ path('app_mission_type_edit', {'id': mission_type.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_mission_type_new') }}">Create new</a>
{% endblock %}
