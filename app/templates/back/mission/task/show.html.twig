            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_mission_task_index') }}">back to list</a>

    <a href="{{ path('app_mission_task_edit', {'id': mission_task.id}) }}">edit</a>

    {{ include('mission_task/_delete_form.html.twig') }}
