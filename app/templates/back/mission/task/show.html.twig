{% extends 'base.html.twig' %}

{% block title %}MissionTask{% endblock %}

{% block body %}
    <h1>MissionTask</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ mission_task.id }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ mission_task.createdAt ? mission_task.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ mission_task.updatedAt ? mission_task.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
