{% extends 'base.html.twig' %}

{% block title %}RaceTrack{% endblock %}

{% block body %}
    <h1>RaceTrack</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ race_track.id }}</td>
            </tr>
            <tr>
                <th>NameEnglish</th>
                <td>{{ race_track.nameEnglish }}</td>
            </tr>
            <tr>
                <th>NameFrench</th>
                <td>{{ race_track.nameFrench }}</td>
            </tr>
            <tr>
                <th>Slug</th>
                <td>{{ race_track.slug }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ race_track.createdAt ? race_track.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ race_track.updatedAt ? race_track.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>DeletedAt</th>
                <td>{{ race_track.deletedAt ? race_track.deletedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_race_track_index') }}">back to list</a>

    <a href="{{ path('app_race_track_edit', {'id': race_track.id}) }}">edit</a>

    {{ include('race_track/_delete_form.html.twig') }}
{% endblock %}
