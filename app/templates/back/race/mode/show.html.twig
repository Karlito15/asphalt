{% extends 'base.html.twig' %}

{% block title %}RaceMode{% endblock %}

{% block body %}
    <h1>RaceMode</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ race_mode.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ race_mode.name }}</td>
            </tr>
            <tr>
                <th>Slug</th>
                <td>{{ race_mode.slug }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ race_mode.createdAt ? race_mode.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ race_mode.updatedAt ? race_mode.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>DeletedAt</th>
                <td>{{ race_mode.deletedAt ? race_mode.deletedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_race_mode_index') }}">back to list</a>

    <a href="{{ path('app_race_mode_edit', {'id': race_mode.id}) }}">edit</a>

    {{ include('race_mode/_delete_form.html.twig') }}
{% endblock %}
