{% extends 'base.html.twig' %}

{% block title %}RaceTime{% endblock %}

{% block body %}
    <h1>RaceTime</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ race_time.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ race_time.name }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ race_time.createdAt ? race_time.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ race_time.updatedAt ? race_time.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>DeletedAt</th>
                <td>{{ race_time.deletedAt ? race_time.deletedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_race_time_index') }}">back to list</a>

    <a href="{{ path('app_race_time_edit', {'id': race_time.id}) }}">edit</a>

    {{ include('race_time/_delete_form.html.twig') }}
{% endblock %}
