<div class="card">

    <div class="card-header">
        <h3 class="card-title">
            {{ 'text.rank'|trans|plural }}
        </h3>
    </div>

    <div class="card-body">

        <div class="d-flex justify-content-around gap-2">
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star0) }}&nbsp;</div>
            {% if entity.stars == 3 %}
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star1) }}&nbsp;</div>
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star2) }}&nbsp;</div>
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star3) }}&nbsp;</div>
            <div class="col d-none text-center">&nbsp;{{ form_label(form.rank.star4) }}&nbsp;</div>
            <div class="col d-none text-center">&nbsp;{{ form_label(form.rank.star5) }}&nbsp;</div>
            <div class="col d-none text-center">&nbsp;{{ form_label(form.rank.star6) }}&nbsp;</div>
            {% elseif entity.stars == 4 %}
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star1) }}&nbsp;</div>
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star2) }}&nbsp;</div>
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star3) }}&nbsp;</div>
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star4) }}&nbsp;</div>
            <div class="col d-none text-center">&nbsp;{{ form_label(form.rank.star5) }}&nbsp;</div>
            <div class="col d-none text-center">&nbsp;{{ form_label(form.rank.star6) }}&nbsp;</div>
            {% elseif entity.stars == 5 %}
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star1) }}&nbsp;</div>
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star2) }}&nbsp;</div>
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star3) }}&nbsp;</div>
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star4) }}&nbsp;</div>
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star5) }}&nbsp;</div>
            <div class="col d-none text-center">&nbsp;{{ form_label(form.rank.star6) }}&nbsp;</div>
            {% elseif entity.stars == 6 %}
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star1) }}&nbsp;</div>
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star2) }}&nbsp;</div>
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star3) }}&nbsp;</div>
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star4) }}&nbsp;</div>
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star5) }}&nbsp;</div>
            <div class="col text-center">&nbsp;{{ form_label(form.rank.star6) }}&nbsp;</div>
            {% endif %}
        </div>
        <div class="d-flex justify-content-around">
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star0 }}" /></div>
            {% if entity.stars == 3 %}
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star1 }}" /></div>
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star2 }}" /></div>
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star3 }}" /></div>
            <div class="col d-none"><twig:FormGroup1 form="{{ form.rank.star4 }}" /></div>
            <div class="col d-none"><twig:FormGroup1 form="{{ form.rank.star5 }}" /></div>
            <div class="col d-none"><twig:FormGroup1 form="{{ form.rank.star6 }}" /></div>
            {% elseif entity.stars == 4 %}
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star1 }}" /></div>
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star2 }}" /></div>
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star3 }}" /></div>
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star4 }}" /></div>
            <div class="col d-none"><twig:FormGroup1 form="{{ form.rank.star5 }}" /></div>
            <div class="col d-none"><twig:FormGroup1 form="{{ form.rank.star6 }}" /></div>
            {% elseif entity.stars == 5 %}
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star1 }}" /></div>
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star2 }}" /></div>
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star3 }}" /></div>
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star4 }}" /></div>
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star5 }}" /></div>
            <div class="col d-none"><twig:FormGroup1 form="{{ form.rank.star6 }}" /></div>
            {% elseif entity.stars == 6 %}
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star1 }}" /></div>
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star2 }}" /></div>
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star3 }}" /></div>
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star4 }}" /></div>
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star5 }}" /></div>
            <div class="col"><twig:FormGroup1 form="{{ form.rank.star6 }}" /></div>
            {% endif %}
        </div>

    </div>

</div>
