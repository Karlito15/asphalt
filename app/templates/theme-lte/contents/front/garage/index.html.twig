{% extends '@App/theme-lte/bases/common/page-index-front.html.twig' %}

{% block table %}
    <tbody>
    {% for item in entities %}
        <tr>
            <td class="{{ classes.table.td }} text-center">{{ loop.index }}</td>
            <td class="{{ classes.table.td }} text-center">{{ item.gameUpdate }}</td>
            <td class="{{ classes.table.td }} text-center">{{ item.class_value }}</td>
            <td class="{{ classes.table.td }} text-start">
                <a
                    href="{{ path('app.garage.update', {id: item.id, slug: item.slug}) }}"
                    class="text-decoration-none {{ _self.color(item.status_unblock, item.status_gold) }}"
                    target="_blank"
                >
                    {{ item.brand }}
                </a>
            </td>
            <td class="{{ classes.table.td }} text-start">
                <a
                    href="{{ path('app.garage.update', {id: item.id, slug: item.slug}) }}"
                    class="text-decoration-none {{ _self.color(item.status_unblock, item.status_gold) }}"
                    target="_blank"
                >
                    {{ item.model }}
                </a>
            </td>
            <td class="{{ classes.table.td }} text-center"><twig:TableBoolean value="{{ item.status_unblock|default(false) }}" /></td>
            <td class="{{ classes.table.td }} text-center"><twig:TableBoolean value="{{ item.status_gold|default(false) }}" /></td>
            <td class="{{ classes.table.td }} text-center"><twig:TableBoolean value="{{ item.status_to_upgrade|default(false) }}" /></td>
            <td class="{{ classes.table.td }} text-end">
                <div class="btn-group no-padding" role="group" aria-label="{{ 'text.action'|trans }}">
                    <a
                        href="{{ path('app.garage.read', {'id': item.id, 'slug': item.slug}) }}"
                        class="{{ classes.button.table }} btn-outline-warning disabled"
                        target="_blank"
                    >
                        <span class="d-md-none d-lg-inline-block">{{ 'btn.read'|trans }}&nbsp;</span>
                        <i class="fa-solid fa-file"></i>
                    </a>
                    <a
                        href="{{ path('app.garage.update', {'id': item.id, 'slug': item.slug}) }}"
                        class="{{ classes.button.table }} btn-outline-info"
                        target="_blank"
                    >
                        <i class="fa-solid fa-pencil"></i>
                        <span class="d-md-none d-lg-inline-block">&nbsp;{{ 'btn.update'|trans }}</span>
                    </a>
                </div>
            </td>
        </tr>
    {% else %}
        <twig:TableEmpty value="{{ 9 }}" />
    {% endfor %}
    </tbody>
    <thead>
        {{ _self.legend() }}
    </thead>
    <tfoot>
        {{ _self.legend() }}
    </tfoot>
{% endblock %}

{% block tableId %}
    {% if current_page == 'app.garage.index' %} id="Garage"{% endif %}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('libraries/bootstrap-table/1.27/dist/bootstrap-table.min.css') }}">
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <!-- Scripts -->
    <script src="{{ asset('libraries/jquery/4.0.0.min.js') }}"></script>
    <script src="{{ asset('libraries/bootstrap-table/1.27/dist/bootstrap-table.min.js') }}"></script>
{#    <script src="https://cdn.jsdelivr.net/npm/bootstrap-table@1.27.1/dist/bootstrap-table-locale-all.min.js"></script>#}
    <script>

        const $table        = $('#Garage');
        const GarageColumns = [];
        console.warn($table);

        function initTable () {
            $table.bootstrapTable({
                locale: 'en-US',
                // locale: 'fr-FR',
                columns: GarageColumns,
                buttonsAlign: 'end',

                cache: false,

                icons: {
                    paginationSwitchDown: 'fa-caret-square-down',
                    paginationSwitchUp: 'fa-caret-square-up',
                    refresh: 'fa-sync',
                    toggleOff: 'fa-toggle-off',
                    toggleOn: 'fa-toggle-on',
                    columns: 'fa-th-list',
                    fullscreen: 'fa-arrows-alt',
                    detailOpen: 'fa-plus',
                    detailClose: 'fa-minus'
                },
                iconSize: 'sm',
                iconsPrefix: 'fa',

                pageList: [20, 40, 60, 80, 100, 'all'],
                pageSize: 15,
                pagination: true,
                paginationHAlign: 'end',
                paginationVAlign: 'bottom',
                paginationLoop: true,

                search: true,
                searchAlign: 'start',
                searchAccentNeutralise: true,
                searchHighlight: true,
                searchTimeOut: 200,
                visibleSearch: false,

                silentSort: false,

                showButtonIcons: true,
                showButtonText: false,
                showColumns: true,
                showColumnsSearch: true,
                showColumnsToggleAll: true,
                showExtendedPagination: true,
                showFullscreen: false,
                showPaginationSwitch: true,
                showSearchButton: false,
                showSearchClearButton: true,
            })
        }
        // Start
        initTable();

    </script>
{% endblock %}

{% macro legend() %}
    <tr>{#  class="sticky-top" #}
        <th class="col-md-auto text-center">&nbsp;</th>
        <th class="col-md-1 text-center" data-sortable="true">{{ 'text.game.update'|trans }}</th>
        <th class="col-md-1 text-center">{{ 'text.class'|trans }}</th>
        <th class="col-md-auto text-start" data-sortable="true">{{ 'text.brand'|trans }}</th>
        <th class="col-md-auto text-start" data-sortable="true">{{ 'text.model'|trans }}</th>
        <th class="col-md-1 text-center text-success">{{ 'text.unblock'|trans }}</th>
        <th class="col-md-1 text-center text-warning">{{ 'text.gold'|trans }}</th>
        <th class="col-md-1 text-center text-info">{{ 'text.to.upgrade'|trans }}</th>
        <th class="col-md-auto text-end">{{ 'text.action'|trans }}</th>
    </tr>
{% endmacro %}

{% macro color(unblock, gold) %}
    {% if unblock == true and gold == false %}
        text-success
    {% elseif unblock == true and gold == true %}
        text-warning
    {% else %}
        text-danger
    {% endif %}
{% endmacro %}
