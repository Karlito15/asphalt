
<h4 class="text-start text-uppercase">
    {{ 'text.common'|trans|plural() }}
</h4>

<div class="row row-cols-1 row-cols-md-4 g-md-3">
    <twig:FormDashboardInventory maxValue="{{ 999 }}" title="{{ 'text.speed'|trans|plural }}" theme="primary" icon="fa-rocket" show="{{ true }}" form="{{ speed }}" />
    <twig:FormDashboardInventory maxValue="{{ 999 }}" title="{{ 'text.acceleration'|trans|plural }}" theme="primary" icon="fa-gauge-high" show="{{ true }}" form="{{ acceleration }}" />
    <twig:FormDashboardInventory maxValue="{{ 999 }}" title="{{ 'text.handling'|trans|plural }}" theme="primary" icon="fa-gear" show="{{ true }}" form="{{ handling }}" />
    <twig:FormDashboardInventory maxValue="{{ 999 }}" title="{{ 'text.nitro'|trans|plural }}" theme="primary" icon="fa-fire" show="{{ true }}" form="{{ nitro }}" />
</div>
