{% extends '@App/theme-lte/bases/common/page-index-front.html.twig' %}

{% block table %}
    <tbody>
    {% for item in entities %}
        <tr>
            <td class="{{ classes.table.td }} text-center">{{ loop.index }}</td>
            <td class="{{ classes.table.td }} text-center">{{ item.garage.gameUpdate }}</td>
            <td class="{{ classes.table.td }} text-center">{{ item.garage.settingClass.value }}</td>
            <td class="{{ classes.table.td }} text-start">
                <a href="{{ path('app.garage.update', {id: item.garage.id, slug: item.garage.slug}) }}" target="_blank" class="text-decoration-none">{{ item.garage.settingBrand.name }}</a>
            </td>
            <td class="{{ classes.table.td }} text-start">
                <a href="{{ path('app.garage.update', {id: item.garage.id, slug: item.garage.slug}) }}" target="_blank" class="text-decoration-none">{{ item.garage.model }}</a>
            </td>
            <td class="{{ classes.table.td }} text-end">
                <div class="btn-group no-padding" role="group" aria-label="{{ 'text.action'|trans }}">
                    <a class="btn btn-sm btn-outline-warning" href="{{ path('app.garage.read', {'id': item.garage.id, 'slug': item.garage.slug}) }}" target="_blank">
                        <span class="d-md-none d-lg-inline-block">{{ 'btn.read'|trans }}&nbsp;</span><i class="fa-solid fa-file"></i>
                    </a>
                    <a class="btn btn-sm btn-outline-info" href="{{ path('app.garage.update', {'id': item.garage.id, 'slug': item.garage.slug}) }}" target="_blank">
                        <i class="fa-solid fa-pencil"></i><span class="d-md-none d-lg-inline-block">&nbsp;{{ 'btn.update'|trans }}</span>
                    </a>
                </div>
            </td>
        </tr>
    {% else %}
        <twig:TableEmpty value="{{ 7 }}" />
    {% endfor %}
    </tbody>
    <thead>
        {{ _self.legend() }}
    </thead>
    <tfoot>
        {{ _self.legend() }}
    </tfoot>
{% endblock %}

{% macro legend() %}
    <tr>{#  class="sticky-top" #}
        <th class="col-xxl-auto text-center">&nbsp;</th>
        <th class="col-xxl-1 text-center" data-sortable="true">{{ 'text.game.update'|trans }}</th>
        <th class="col-xxl-1 text-center">{{ 'text.class'|trans }}</th>
        <th class="col-xxl-auto text-start" data-sortable="true">{{ 'text.brand'|trans }}</th>
        <th class="col-xxl-auto text-start" data-sortable="true">{{ 'text.model'|trans }}</th>
        <th class="col-xxl-auto text-end">{{ 'text.action'|trans }}</th>
    </tr>
{% endmacro %}
