{% extends '@App/bases/front/full.html.twig' %}

{% block content %}

<div class="card">
    <div class="card-header">

        <div class="row row-cols-2">
            <div class="col-md-3">
                <h2 class="h1">{{ controller_name }}</h2>
            </div>

            {% if current_page == 'app.garage.index' %}
                {# Garage #}
            <div class="col-md-6"></div>
            <div class="col-md-3">
                <a class="float-end {{ classes.button.success }} btn-lg" href="{{ path(links.create) }}">
                    {{ 'btn.create'|trans }}&nbsp;<i class="fa fa-plus-square"></i>
                </a>
            </div>
            {% elseif app.current_route starts with 'app.page' %}
                {# Pages #}
            <div class="col-md-3"></div>
            <div class="col-md-6">
                {# <twig:ListClass link="{{ app.current_route }}" /> #}
            </div>
            {% elseif app.current_route starts with 'app.search' %}
                {# Search #}
            <div class="col-md-9">
                {% include '@App/contents/front/search/_form.html.twig' %}
            </div>
            {% else %}
            <div class="col-md-9 datatable-toolbar">&nbsp;</div>
            {% endif %}

        </div>

    </div>

    <div class="card-body">
        <table class="table table-bordered table-striped"{% block id %}{% endblock %}>
            {% block table %}{% endblock %}
        </table>
    </div>

</div>

{% endblock %}
