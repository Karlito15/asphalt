{% extends '@App/theme-aero/bases/common/page-index-back.html.twig' %}

{% block table %}

    <tbody>
    {% for item in entities %}
        <tr>
            <td class="{{ classes.table.td }}">{{ item.id }}</td>
            <td class="{{ classes.table.td }}">{{ item.level }}</td>
            <td class="{{ classes.table.td }}">{{ item.common }}</td>
            <td class="{{ classes.table.td }}">{{ item.rare }}</td>
            <td class="{{ classes.table.td }}">{{ item.epic }}</td>
            <td class="{{ classes.table.td }}">{{ item.slug }}</td>
            <td class="{{ classes.table.td }}"><twig:TableDate value="{{ item.createdAt }}" /></td>
            <td class="{{ classes.table.td }}"><twig:TableDate value="{{ item.updatedAt }}" /></td>
            <td class="{{ classes.table.td }} text-end">
                <a href="{{ path(links.update, {'id': item.id}) }}" class="{{ classes.button.table }} btn-outline-info">
                    {{ 'text.update'|trans }}
                </a>
            </td>
        </tr>
    {% else %}
        <twig:TableEmpty value="{{ 9 }}" />
    {% endfor %}
    </tbody>

    <thead>
        {{ _self.legend() }}
    </thead>
    <tfoot>
        {{ _self.legend() }}
    </tfoot>
{% endblock %}

{% macro legend() %}
    <tr>
        <th>{{ 'text.id'|trans }}</th>
        <th>{{ 'text.level'|trans }}</th>
        <th>{{ 'text.common'|trans }}</th>
        <th>{{ 'text.rare'|trans }}</th>
        <th>{{ 'text.epic'|trans }}</th>
        <th>{{ 'text.slug'|trans }}</th>
        <th>{{ 'text.date.created.at'|trans }}</th>
        <th>{{ 'text.date.updated.at'|trans }}</th>
        <th class="text-end">{{ 'text.action'|trans }}</th>
    </tr>
{% endmacro %}
