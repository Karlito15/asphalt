{% block content %}

<div class="card">
    <div class="card-header">

        <div class="row row-col-2 row-gap-5">
            <div class="col-3">
                <h2 class="h1">{{ controller_name }}</h2>
            </div>
            <div class="col-6"></div>
            <div class="col-3">
                <a class="float-end btn btn-lg btn-outline-success w-100 text-uppercase" href="{{ path(links.create) }}">
                    {{ 'btn.create'|trans }}&nbsp;<i class="fa fa-plus-square"></i>
                </a>
            </div>
        </div>

    </div>
    <div class="card-body">
        <table class="table table-bordered table-striped">
            {% block table %}{% endblock %}
        </table>
    </div>
</div>

{% endblock %}

{% extends '@App/theme-kw/bases/back/full.html.twig' %}
