{% extends 'base.html.twig' %}

{% block title %}GarageBlueprint index{% endblock %}

{% block body %}
    <h1>GarageBlueprint index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for garage_blueprint in garage_blueprints %}
            <tr>
                <td>{{ garage_blueprint.id }}</td>
                <td>
                    <a href="{{ path('app_garage_blueprint_show', {'id': garage_blueprint.id}) }}">show</a>
                    <a href="{{ path('app_garage_blueprint_edit', {'id': garage_blueprint.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="2">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_garage_blueprint_new') }}">Create new</a>
{% endblock %}
