
<div class="card-title">
    <h4 class="text-center">{{ 'text.unit-price'|trans|plural }}</h4>
</div>
<table class="{{ classes.table }}">
    <thead class="text-center">
        <tr>
            <th colspan="13">{{ 'text.level'|trans|plural }}</th>
            <th colspan="3">{{ 'text.import'|trans|plural }}</th>
        </tr>
        <tr>
            <th class="small">{{ '01' }}</th>
            <th class="small">{{ '02' }}</th>
            <th class="small">{{ '03' }}</th>
            <th class="small">{{ '04' }}</th>
            <th class="small">{{ '05' }}</th>
            <th class="small">{{ '06' }}</th>
            <th class="small">{{ '07' }}</th>
            <th class="small">{{ '08' }}</th>
            <th class="small">{{ '09' }}</th>
            <th class="small">{{ '10' }}</th>
            <th class="small">{{ '11' }}</th>
            <th class="small">{{ '12' }}</th>
            <th class="small">{{ '13' }}</th>
            <th class="small">{{ 'text.common'|trans }}</th>
            <th class="small">{{ 'text.rare'|trans }}</th>
            <th class="small">{{ 'text.epic'|trans }}</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td class="small text-end">{{ _self.price(4, entity.settingUnitPrice.level01) }}</td>
            <td class="small text-end">{{ _self.price(4, entity.settingUnitPrice.level02) }}</td>
            <td class="small text-end">{{ _self.price(4, entity.settingUnitPrice.level03) }}</td>
            <td class="small text-end">{{ _self.price(4, entity.settingUnitPrice.level04) }}</td>
            <td class="small text-end">{{ _self.price(4, entity.settingUnitPrice.level05) }}</td>
            <td class="small text-end">{{ _self.price(4, entity.settingUnitPrice.level06) }}</td>
            <td class="small text-end">{{ _self.price(4, entity.settingUnitPrice.level07) }}</td>
            <td class="small text-end">{{ _self.price(4, entity.settingUnitPrice.level08) }}</td>
            <td class="small text-end">{{ _self.price(4, entity.settingUnitPrice.level09) }}</td>
            <td class="small text-end">{{ _self.price(4, entity.settingUnitPrice.level10) }}</td>
            <td class="small text-end">{{ _self.price(4, entity.settingUnitPrice.level11) }}</td>
            <td class="small text-end">{{ _self.price(4, entity.settingUnitPrice.level12) }}</td>
            <td class="small text-end">{{ _self.price(4, entity.settingUnitPrice.level13) }}</td>
            <td class="small text-end">{{ _self.price(entity.upgrade.common, entity.settingUnitPrice.common) }}</td>
            <td class="small text-end">{{ _self.price(entity.upgrade.rare, entity.settingUnitPrice.rare) }}</td>
            <td class="small text-end">{{ _self.price(entity.upgrade.epic, entity.settingUnitPrice.epic) }}</td>
        </tr>
        <tr>
            <td class="small text-center" colspan="16">TO DO</td>
        </tr>
    </tbody>
</table>

{% macro price(level, price) %}
    {{ (price * level)|number_format }}
{% endmacro %}
