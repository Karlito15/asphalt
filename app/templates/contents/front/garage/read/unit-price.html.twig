
<div class="card-title">
    <h4 class="text-center">
        {{ 'text.unit-price'|trans|plural }}
    </h4>
</div>
<table class="table table-bordered table-striped">
    <thead class="text-center">
        <tr>
            <th colspan="13">{{ 'text.level'|trans|plural }}</th>
            <th colspan="3">{{ 'text.import'|trans|plural }}</th>
        </tr>
        <tr>
            <th>{{ '01' }}</th>
            <th>{{ '02' }}</th>
            <th>{{ '03' }}</th>
            <th>{{ '04' }}</th>
            <th>{{ '05' }}</th>
            <th>{{ '06' }}</th>
            <th>{{ '07' }}</th>
            <th>{{ '08' }}</th>
            <th>{{ '09' }}</th>
            <th>{{ '10' }}</th>
            <th>{{ '11' }}</th>
            <th>{{ '12' }}</th>
            <th>{{ '13' }}</th>
            <th>{{ 'text.common'|trans }}</th>
            <th>{{ 'text.rare'|trans }}</th>
            <th>{{ 'text.epic'|trans }}</th>
        </tr>
    </thead>
    <tbody class="text-center">
        <tr>
            <td>{{ _self.price(4, entity.settingUnitPrice.level01) }}</td>
            <td>{{ _self.price(4, entity.settingUnitPrice.level02) }}</td>
            <td>{{ _self.price(4, entity.settingUnitPrice.level03) }}</td>
            <td>{{ _self.price(4, entity.settingUnitPrice.level04) }}</td>
            <td>{{ _self.price(4, entity.settingUnitPrice.level05) }}</td>
            <td>{{ _self.price(4, entity.settingUnitPrice.level06) }}</td>
            <td>{{ _self.price(4, entity.settingUnitPrice.level07) }}</td>
            <td>{{ _self.price(4, entity.settingUnitPrice.level08) }}</td>
            <td>{{ _self.price(4, entity.settingUnitPrice.level09) }}</td>
            <td>{{ _self.price(4, entity.settingUnitPrice.level10) }}</td>
            <td>{{ _self.price(4, entity.settingUnitPrice.level11) }}</td>
            <td>{{ _self.price(4, entity.settingUnitPrice.level12) }}</td>
            <td>{{ _self.price(4, entity.settingUnitPrice.level13) }}</td>
            <td>{{ _self.price(entity.upgrade.common, entity.settingUnitPrice.common) }}</td>
            <td>{{ _self.price(entity.upgrade.rare, entity.settingUnitPrice.rare) }}</td>
            <td>{{ _self.price(entity.upgrade.epic, entity.settingUnitPrice.epic) }}</td>
        </tr>
        <tr>
            <td class="text-center" colspan="16">TO DO</td>
        </tr>
    </tbody>
</table>

{% macro price(level, price) %}
    {{ (price * level)|number_format }}
{% endmacro %}
