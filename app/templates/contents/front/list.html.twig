{% block content %}

<div class="card">
    <div class="card-header">

        <div class="row row-cols-2">
            <div class="col-xxl-9">
                <h2 class="h1">{{ controller_name }}</h2>
            </div>

            {% if current_page == 'app.garage.index' %}
                {# Garage #}
            <div class="col-xxl-18"></div>
            <div class="col-xxl-9">
                <a class="float-end btn btn-lg btn-outline-success w-100 text-uppercase" href="{{ path(links.create) }}">
                    {{ 'btn.create'|trans }}&nbsp;<i class="fa fa-plus-square"></i>
                </a>
            </div>
            {% elseif app.current_route starts with 'app.page' %}
                {# Pages #}
            <div class="col-xxl-9"></div>
            <div class="col-xxl-18">
                <twig:ListClass link="{{ app.current_route }}" />
            </div>
            {% elseif app.current_route starts with 'app.search' %}
                {# Search #}
            <div class="col-xxl-27">
                {% include '@App/contents/front/search/_form.html.twig' %}
            </div>
            {% else %}
            <div class="col-xxl-27 datatable-toolbar">&nbsp;</div>
            {% endif %}

        </div>

    </div>
    <div class="card-body">
        <table class="{{ classes.table.default }}"{% block id %}{% endblock %}>
            {% block table %}{% endblock %}
        </table>
    </div>
</div>

{% endblock %}

{% extends '@App/bases/front/full.html.twig' %}
