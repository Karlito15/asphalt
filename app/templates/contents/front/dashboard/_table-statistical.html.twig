{% macro legend() %}
    <tr class="table-secondary small">
        <th class="my-0 py-1 align-middle text-start">{{ 'text.legend'|trans }}</th>
        <th class="my-0 py-1 align-middle text-center"><span class="d-md-none d-lg-inline-block">{{ 'text.class'|trans }}&nbsp;</span>D</th>
        <th class="my-0 py-1 align-middle text-center"><span class="d-md-none d-lg-inline-block">{{ 'text.class'|trans }}&nbsp;</span>C</th>
        <th class="my-0 py-1 align-middle text-center"><span class="d-md-none d-lg-inline-block">{{ 'text.class'|trans }}&nbsp;</span>B</th>
        <th class="my-0 py-1 align-middle text-center"><span class="d-md-none d-lg-inline-block">{{ 'text.class'|trans }}&nbsp;</span>A</th>
        <th class="my-0 py-1 align-middle text-center"><span class="d-md-none d-lg-inline-block">{{ 'text.class'|trans }}&nbsp;</span>S</th>
        <th class="my-0 py-1 align-middle text-end">{{ 'text.total'|trans }}</th>
    </tr>
{% endmacro %}
