{% block table %}
        <tbody>
        {% for item in entities %}
            <tr>
                <td>{{ item.Mode }}</td>
                <td>{{ item.Season }}</td>
                <td>{{ item.Region }}</td>
                <td>{{ item.English }}</td>
                <td>{{ item.French }}</td>
                <td>{{ item.Chapter }}</td>
                <td>{{ item.Order }}</td>
                <td>{{ item.Time }}</td>
                <td>{{ item.Finished }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="11">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
        <thead>
            {{ _self.legend() }}
        </thead>
        <tfoot>
            {{ _self.legend() }}
        </tfoot>
{% endblock %}

{% block id %} id="Race"{% endblock %}

{% macro legend() %}
            <tr class="sticky-top">
                <th>{{ 'text.mode'|trans }}</th>
                <th>{{ 'text.season'|trans }}</th>
                <th>{{ 'text.region'|trans }}</th>
                <th>{{ 'text.name.english'|trans|raw }}</th>
                <th>{{ 'text.name.french'|trans|raw }}</th>
                <th>{{ 'text.chapter'|trans }}</th>
                <th>{{ 'text.race.order'|trans|raw }}</th>
                <th>{{ 'text.time'|trans }}</th>
                <th>{{ 'text.finished'|trans }}</th>
            </tr>
{% endmacro %}

{% extends '@App/contents/front/list.html.twig' %}
