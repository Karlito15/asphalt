
<!-- Search -->
{{ form_start(form, {'attr': {'class': 'm-0'}}) }}
<div class="row gx-2 gy-3 m-0 bg-primary-subtle">

    {% if app.current_route == 'app.search.race' %}
    <div class="col">{{ form_row(form.mode) }}</div>
    <div class="col">{{ form_row(form.region) }}</div>
    <div class="col">{{ form_row(form.season) }}</div>
    <div class="col">{{ form_row(form.time) }}</div>
    <div class="col">{{ form_row(form.raceOrder) }}</div>
    {% elseif app.current_route == 'app.search.garage' %}
    <div class="col">{{ form_row(form.gameUpdate) }}</div>
    <div class="col">{{ form_row(form.brand) }}</div>
    <div class="col">{{ form_row(form.classLetter) }}</div>
    <div class="col">{{ form_row(form.unblock) }}</div>
    <div class="col">{{ form_row(form.gold) }}</div>
    {% endif %}

    <div class="col">
        <div class="btn-group" role="group" aria-label="button">
            <button class="btn btn-outline-danger text-uppercase" type="reset">Reset</button>
            <button class="btn btn-outline-success text-uppercase" type="submit">Submit</button>
        </div>
    </div>
{#    <div class="col text-end">#}
{#        <p class="pe-none btn btn-primary position-relative">#}
{#            Result <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">{{ count }}</span>#}
{#        </p>#}
{#    </div>#}
</div>

{#{{ form_errors(form) }}#}
{#{{ form_rest(form) }}#}
{{ form_end(form) }}
