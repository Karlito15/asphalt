{% block table %}

    <tbody>
    {% for item in entities %}
        <tr>
            <td class="{{ classes.table.td }}">{{ item.id }}</td>
            <td class="{{ classes.table.td }}">{{ item.value }}</td>
            <td class="{{ classes.table.td }}">{{ item.slug }}</td>
            <twig:TableDate entity="{{ item }}" />
        {% if app.current_route == 'admin.mission.task.index' %}
            <twig:TableActionSimple id="{{ item.id }}" link="{{ 'admin.mission.task.update' }}" />
        {% elseif app.current_route == 'admin.mission.type.index' %}
            <twig:TableActionSimple id="{{ item.id }}" link="{{ 'admin.mission.type.update' }}" />
        {% endif %}
        </tr>
    {% else %}
        <twig:TableEmpty value="6" />
    {% endfor %}
    </tbody>

    <thead>
        {{ _self.legend() }}
    </thead>
    <tfoot>
        {{ _self.legend() }}
    </tfoot>
{% endblock %}

{% macro legend() %}
    <tr>
        <th>{{ 'text.id'|trans }}</th>
        <th>{{ 'text.value'|trans }}</th>
        <th>{{ 'text.slug'|trans }}</th>
        <th class="text-end">{{ 'text.date.created.at'|trans }}</th>
        <th class="text-end">{{ 'text.date.updated.at'|trans }}</th>
        <th class="text-end">{{ 'text.action'|trans }}</th>
    </tr>
{% endmacro %}

{% extends '@App/contents/back/list.html.twig' %}
