{% extends '@App/bases/common/page-index-back.html.twig' %}

{% block table %}

    <tbody>
    {% for item in entities %}
        <tr>
            <td class="{{ classes.table.td }}">{{ item.Season.Chapter }}</td>
            <td class="{{ classes.table.td }}">{{ item.raceOrder }}</td>
            <td class="{{ classes.table.td }} text-truncate">{{ item.Mode }}</td>
            <td class="{{ classes.table.td }} text-truncate">{{ item.Season }}</td>
            <td class="{{ classes.table.td }} text-truncate">{{ item.Track.nameEnglish }}</td>
            <td class="{{ classes.table.td }} text-truncate">{{ item.Track.nameFrench }}</td>
            <td class="{{ classes.table.td }} text-center">{{item.Time }}</td>
            <td class="{{ classes.table.td }} text-center">{# {{ component('ValueBoolean', {value: item.Finished}) }} #}</td>
            <td class="{{ classes.table.td }}"><twig:TableDate value="{{ item.createdAt }}" /></td>
            <td class="{{ classes.table.td }}"><twig:TableDate value="{{ item.updatedAt }}" /></td>
            <td class="{{ classes.table.td }} text-end">
                <a href="{{ path(links.update, {'id': item.id}) }}" class="{{ classes.button.table }} btn-outline-info">
                    {{ 'text.update'|trans }}
                </a>
            </td>
        </tr>
    {% else %}
        <twig:TableEmpty value="9" />
    {% endfor %}
    </tbody>

    <thead>
        {{ _self.legend() }}
    </thead>
    <tfoot>
        {{ _self.legend() }}
    </tfoot>
{% endblock %}

{% macro legend() %}
    <tr>
        <th>{{ 'text.chapter'|trans }}</th>
        <th>{{ 'text.race.order'|trans|raw }}</th>
        <th>{{ 'text.mode'|trans }}</th>
        <th>{{ 'text.season'|trans }}</th>
        <th>{{ 'text.name.english'|trans|raw }}</th>
        <th>{{ 'text.name.french'|trans|raw }}</th>
        <th>{{ 'text.time'|trans }}</th>
        <th>{{ 'text.finished'|trans }}</th>
        <th>{{ 'text.date.created.at'|trans }}</th>
        <th>{{ 'text.date.updated.at'|trans }}</th>
        <th class="text-end">{{ 'text.action'|trans }}</th>
    </tr>
{% endmacro %}
