{% extends 'base.html.twig' %}

{% block title %}RaceSeason{% endblock %}

{% block body %}
    <h1>RaceSeason</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ race_season.id }}</td>
            </tr>
            <tr>
                <th>Chapter</th>
                <td>{{ race_season.chapter }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ race_season.name }}</td>
            </tr>
            <tr>
                <th>Slug</th>
                <td>{{ race_season.slug }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ race_season.createdAt ? race_season.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ race_season.updatedAt ? race_season.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>DeletedAt</th>
                <td>{{ race_season.deletedAt ? race_season.deletedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_race_season_index') }}">back to list</a>

    <a href="{{ path('app_race_season_edit', {'id': race_season.id}) }}">edit</a>

    {{ include('race_season/_delete_form.html.twig') }}
{% endblock %}
