{% extends '@App/bases/common/page-index-back.html.twig' %}

{% block table %}

    <tbody>
    {% for item in entities %}
        <tr>
            <td class="{{ classes.table.td }}">{{ item.id }}</td>
            <td class="{{ classes.table.td }}">{{ item.star1 }}</td>
            <td class="{{ classes.table.td }}">{{ item.star2 }}</td>
            <td class="{{ classes.table.td }}">{{ item.star3 }}</td>
            <td class="{{ classes.table.td }}">{{ item.star4 }}</td>
            <td class="{{ classes.table.td }}">{{ item.star5 }}</td>
            <td class="{{ classes.table.td }}">{{ item.star6 }}</td>
            <td class="{{ classes.table.td }}">{{ item.total }}</td>
            <td class="{{ classes.table.td }}">{{ item.slug }}</td>
            <td class="{{ classes.table.td }}"><twig:TableDate value="{{ item.createdAt }}" /></td>
            <td class="{{ classes.table.td }}"><twig:TableDate value="{{ item.updatedAt }}" /></td>
            <td class="{{ classes.table.td }} text-end">
                <a href="{{ path(links.update, {'id': item.id}) }}" class="{{ classes.button.table }} btn-outline-info">
                    {{ 'text.update'|trans }}
                </a>
            </td>
        </tr>
    {% else %}
        <twig:TableEmpty value="{{ 12 }}" />
    {% endfor %}
    </tbody>

    <thead>
        {{ _self.legend() }}
    </thead>
    <tfoot>
        {{ _self.legend() }}
    </tfoot>
{% endblock %}

{% macro legend() %}
    <tr>
        <th>{{ 'text.id'|trans }}</th>
        <th>{{ 'text.star1'|trans }}</th>
        <th>{{ 'text.star2'|trans }}</th>
        <th>{{ 'text.star3'|trans }}</th>
        <th>{{ 'text.star4'|trans }}</th>
        <th>{{ 'text.star5'|trans }}</th>
        <th>{{ 'text.star6'|trans }}</th>
        <th>{{ 'text.total'|trans }}</th>
        <th>{{ 'text.slug'|trans }}</th>
        <th>{{ 'text.date.created.at'|trans }}</th>
        <th>{{ 'text.date.updated.at'|trans }}</th>
        <th class="text-end">{{ 'text.action'|trans }}</th>
    </tr>
{% endmacro %}
