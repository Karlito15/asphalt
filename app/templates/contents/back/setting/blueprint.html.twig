{% block table %}

    <tbody>
    {% for item in entities %}
        <tr>
            <td class="{{ classes.td }}">{{ item.id }}</td>
            <td class="{{ classes.td }}">{{ item.star1 }}</td>
            <td class="{{ classes.td }}">{{ item.star2 }}</td>
            <td class="{{ classes.td }}">{{ item.star3 }}</td>
            <td class="{{ classes.td }}">{{ item.star4 }}</td>
            <td class="{{ classes.td }}">{{ item.star5 }}</td>
            <td class="{{ classes.td }}">{{ item.star6 }}</td>
            <td class="{{ classes.td }}">{{ item.total }}</td>
            <td class="{{ classes.td }}">{{ item.slug }}</td>
            <twig:TableDate entity="{{ item }}" />
            <twig:TableAction id="{{ item.id }}" link="{{ 'admin.setting.blueprint.update' }}" />
        </tr>
    {% else %}
        <twig:TableEmpty value="11" />
    {% endfor %}
    </tbody>

    <thead>
        {{ _self.legend() }}
    </thead>
    <tfoot>
        {{ _self.legend() }}
    </tfoot>
{% endblock %}

{% macro legend() %}
    <tr>
        <th>{{ 'text.id'|trans }}</th>
        <th>{{ 'text.star1'|trans }}</th>
        <th>{{ 'text.star2'|trans }}</th>
        <th>{{ 'text.star3'|trans }}</th>
        <th>{{ 'text.star4'|trans }}</th>
        <th>{{ 'text.star5'|trans }}</th>
        <th>{{ 'text.star6'|trans }}</th>
        <th>{{ 'text.total'|trans }}</th>
        <th>{{ 'text.slug'|trans }}</th>
        <th>{{ 'text.date.created.at'|trans }}</th>
        <th>{{ 'text.date.updated.at'|trans }}</th>
        <th>{{ 'text.action'|trans }}</th>
    </tr>
{% endmacro %}

{% extends '@App/contents/back/list.html.twig' %}
