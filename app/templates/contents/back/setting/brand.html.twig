{% block table %}

    <tbody>
    {% for item in entities %}
        <tr>
            <td class="{{ classes.table.td }}">{{ item.id }}</td>
            <td class="{{ classes.table.td }}">{{ item.name }}</td>
            <td class="{{ classes.table.td }}">{{ item.carsNumber }}</td>
            <td class="{{ classes.table.td }}">{{ item.slug }}</td>
            <twig:TableDate entity="{{ item }}" />
            <twig:TableActionSimple id="{{ item.id }}" link="{{ 'admin.setting.brand.update' }}" />
        </tr>
    {% else %}
        <twig:TableEmpty value="7" />
    {% endfor %}
    </tbody>

    <thead>
        {{ _self.legend() }}
    </thead>
    <tfoot>
        {{ _self.legend() }}
    </tfoot>
{% endblock %}

{% macro legend() %}
    <tr>
        <th>{{ 'text.id'|trans }}</th>
        <th>{{ 'text.name'|trans }}</th>
        <th>{{ 'text.number'|trans }}</th>
        <th>{{ 'text.slug'|trans }}</th>
        <th class="text-end">{{ 'text.date.created.at'|trans }}</th>
        <th class="text-end">{{ 'text.date.updated.at'|trans }}</th>
        <th class="text-end">{{ 'text.action'|trans }}</th>
    </tr>
{% endmacro %}

{% extends '@App/contents/back/list.html.twig' %}
