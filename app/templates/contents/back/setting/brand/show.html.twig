{% extends 'base.html.twig' %}

{% block title %}SettingBrand{% endblock %}

{% block body %}
    <h1>SettingBrand</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ setting_brand.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ setting_brand.name }}</td>
            </tr>
            <tr>
                <th>Cars_number</th>
                <td>{{ setting_brand.carsNumber }}</td>
            </tr>
            <tr>
                <th>Slug</th>
                <td>{{ setting_brand.slug }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ setting_brand.createdAt ? setting_brand.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ setting_brand.updatedAt ? setting_brand.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>DeletedAt</th>
                <td>{{ setting_brand.deletedAt ? setting_brand.deletedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_setting_brand_index') }}">back to list</a>

    <a href="{{ path('app_setting_brand_edit', {'id': setting_brand.id}) }}">edit</a>

    {{ include('setting_brand/_delete_form.html.twig') }}
{% endblock %}
