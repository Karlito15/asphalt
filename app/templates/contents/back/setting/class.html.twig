{% block table %}

    <tbody>
    {% for item in entities %}
        <tr>
            <td class="{{ classes.td }}">{{ item.id }}</td>
            <td class="{{ classes.td }}">{{ item.label }}</td>
            <td class="{{ classes.td }}">{{ item.value }}</td>
            <td class="{{ classes.td }}">{{ item.classOrder }}</td>
            <td class="{{ classes.td }}">{{ item.carsNumber }}</td>
            <td class="{{ classes.td }}">{{ item.median }}</td>
            <td class="{{ classes.td }}">{{ item.slug }}</td>
            <twig:TableDate entity="{{ item }}" />
            <twig:TableAction id="{{ item.id }}" link="{{ 'admin.setting.class.update' }}" />
        </tr>
    {% else %}
        <twig:TableEmpty value="10" />
    {% endfor %}
    </tbody>

    <thead>
        {{ _self.legend() }}
    </thead>
    <tfoot>
        {{ _self.legend() }}
    </tfoot>
{% endblock %}

{% macro legend() %}
    <tr>
        <th>{{ 'text.id'|trans }}</th>
        <th>{{ 'text.level'|trans }}</th>
        <th>{{ 'text.value'|trans }}</th>
        <th>{{ 'text.order'|trans }}</th>
        <th>{{ 'text.number'|trans }}</th>
        <th>{{ 'text.median'|trans }}</th>
        <th>{{ 'text.slug'|trans }}</th>
        <th>{{ 'text.date.created.at'|trans }}</th>
        <th>{{ 'text.date.updated.at'|trans }}</th>
        <th>{{ 'text.action'|trans }}</th>
    </tr>
{% endmacro %}

{% extends '@App/contents/back/list.html.twig' %}
